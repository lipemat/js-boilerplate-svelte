{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": false,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2024",
    "verbatimModuleSyntax": true,
    "paths": {
      "@typescript-eslint/utils/ts-eslint": [
        "./node_modules/@typescript-eslint/utils/dist/ts-eslint"
      ]
    }
  },
  "include": [
    "bin/**/*ts",
    "config/**/*ts",
    "helpers/**/*ts",
    "lib/**/*ts",
    "jest/jest.config.ts",
    "jest/tests/**/*ts",
    "svelte-plugins/**/*ts",
    "types"
  ]
}
