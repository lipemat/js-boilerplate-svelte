{
  "name": "@lipemat/js-boilerplate-svelte",
  "version": "2.1.0-beta.1",
  "description": "Svelte extension for @lipemat/js-boilerplate",
  "license": "MIT",
  "engines": {
    "node": ">=22.21.1"
  },
  "type": "module",
  "files": [
    "bin/",
    "config/",
    "helpers/"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lipemat/js-boilerplate-svelte.git"
  },
  "bugs": {
    "url": "https://github.com/lipemat/js-boilerplate-svelte/issues"
  },
  "homepage": "https://github.com/lipemat/js-boilerplate-svelte#readme",
  "bin": {
    "lipemat-js-boilerplate-svelte": "./bin/lipemat-js-boilerplate-svelte"
  },
  "scripts": {
    "build": "tsc --project ./bin",
    "prepublishOnly": "yarn run build",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ./jest.config.ts",
    "validate-ts": "tsc --noEmit",
    "watch": "tsc --project ./bin --watch"
  },
  "dependencies": {
    "@lipemat/eslint-config": "^5.2.0-beta.3",
    "@lipemat/js-boilerplate-shared": ">=0.2.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/eslint": "^9",
    "@typescript-eslint/parser": "^8.18.0",
    "@typescript-eslint/types": "^8.44.0",
    "eslint": "^9",
    "eslint-plugin-svelte": "^3.11.0",
    "loader-utils": "^3.3.1",
    "postcss-scss": "^4.0.4",
    "require-json5": "^1.3.0",
    "svelte": "^4.2.19",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.3.1",
    "svelte-loader": "^3.1.9",
    "svelte-preprocess": "^6.0.3",
    "svelte-preprocess-cssmodules": "^2.2.5",
    "typescript-eslint": "^8.18.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@lipemat/js-boilerplate": "^11.0.0-beta.4",
    "@types/jest": "^30.0.0",
    "@types/loader-utils": "^2.0.6",
    "@types/node": "^22",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "eslint": "^9",
    "jest": "^30.3.0",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1"
  },
  "peerDependencies": {
    "@lipemat/js-boilerplate": ">=11.0.0-beta.4",
    "eslint": "^9"
  },
  "packageManager": "yarn@4.13.0"
}
